# Research Agent — Environment Variables
# Copy to .env and fill in the keys for your chosen provider.
# Never commit .env to git.

# ── Provider selector ─────────────────────────────────────────────────────────
# Which LLM backend to use. Options:
#   anthropic | openai | openrouter | deepseek | qwen | minimax | ollama | gatellm | custom
LLM_PROVIDER=anthropic

# ── API keys — set only the one you need ─────────────────────────────────────

# Anthropic Claude  →  https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI ChatGPT    →  https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenRouter        →  https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# DeepSeek          →  https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# Alibaba Qwen      →  https://dashscope.aliyuncs.com/
QWEN_API_KEY=sk-...

# MiniMax           →  https://www.minimaxi.chat/
MINIMAX_API_KEY=...

# Ollama (local, no key required)
# Install: https://ollama.com/  •  then: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# GateLLM (gatellm.ru — OpenAI-compatible gateway with many models)
GATELLM_API_KEY=sk-...

# Custom OpenAI-compatible endpoint (LLM_PROVIDER=custom)
CUSTOM_API_BASE_URL=https://my-llm.example.com/v1
CUSTOM_API_KEY=sk-...

# ── Web search ────────────────────────────────────────────────────────────────
# Используется DuckDuckGo — бесплатно, без ключа.
# Ничего не нужно настраивать.

# ── Model ID ──────────────────────────────────────────────────────────────────
# Override the default model for your chosen provider. Examples:
#
# anthropic:   claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5
# openai:      gpt-4o | gpt-4o-mini | o1 | o3-mini
# openrouter:  meta-llama/llama-3.3-70b-instruct | mistral/mistral-small-3.1-24b
# deepseek:    deepseek-chat | deepseek-reasoner
# qwen:        qwen-plus | qwen-turbo | qwen-max | qwen-long
# minimax:     MiniMax-Text-01
# ollama:      llama3.2 | mistral | gemma3 | phi4 | qwen2.5
# gatellm:     qwen/qwen-2.5-72b-instruct | meta-llama/llama-3.3-70b-instruct
# custom:      depends on your endpoint
DEFAULT_MODEL=claude-sonnet-4-6

# ── Agent settings ────────────────────────────────────────────────────────────
MAX_STEPS=10
REQUEST_TIMEOUT=30

# ── Output ────────────────────────────────────────────────────────────────────
REPORTS_DIR=research/

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
